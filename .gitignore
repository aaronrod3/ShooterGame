# ============================================
# UE5 SHOOTERGAME - .gitignore
# ============================================

# Auto-generated build/temp folders - Rider/UE5 rebuilds these locally
Binaries/
Build/
Intermediate/
Saved/
DerivedDataCache/
.vs/
*.sln
*.suo
*.user

# Marketplace assets - all re-downloadable from Fab, no need to store
Content/Assets/

# Auto-generated by UE5 World Partition - rebuilt when you open the map
Content/__ExternalActors__/
Content/__ExternalObjects__/
